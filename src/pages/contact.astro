---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Reach out to The Diet Guru for health and nutrition inquiries. We're here to help you on your wellness journey."
  keywords={['contact diet guru', 'nutrition support', 'health inquiries']}
  canonicalPath="/contact"
>
  <main class="contact-page">
    <div class="contact-inner">
      <!-- Header -->
      <header class="page-header">
        <h1 class="page-title">Contact The Diet Guru</h1>
        <p class="page-subtitle">
          Have a question about nutrition, our content, or partnerships?
          We'd love to hear from you.
        </p>
      </header>

      <div class="contact-grid">
        <!-- Contact Form -->
        <div class="form-card">
          <h2 class="card-title">Get in Touch</h2>
          <form class="contact-form" action="#" method="POST" id="contact-form">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" placeholder="Dr. Jane Smith" required />
            </div>
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="jane@example.com" required />
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <select id="subject" name="subject" required>
                <option value="" disabled selected>Select a topic...</option>
                <option value="general">General Inquiry</option>
                <option value="nutrition">Nutrition Question</option>
                <option value="partnership">Partnership / Media</option>
                <option value="content">Content Submission</option>
                <option value="technical">Technical Issue</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" placeholder="Tell us how we can help..." required></textarea>
            </div>
            <button type="submit" class="submit-btn">Send Message</button>
          </form>
        </div>

        <!-- Info Column -->
        <div class="info-col">
          <!-- Office -->
          <div class="info-card">
            <span class="info-icon" aria-hidden="true">📍</span>
            <h3 class="info-title">Our Office</h3>
            <address class="info-text">
              The Diet Guru Headquarters<br />
              123 Innovation Drive, Suite 400<br />
              Tech Valley, CA 94043
            </address>
          </div>

          <!-- Email -->
          <div class="info-card">
            <span class="info-icon" aria-hidden="true">📧</span>
            <h3 class="info-title">Direct Contact</h3>
            <p class="info-text">
              <a href="mailto:support@thedietguru.org">support@thedietguru.org</a>
            </p>
          </div>

          <!-- Medical Disclaimer -->
          <div class="disclaimer-card">
            <span class="disclaimer-icon" aria-hidden="true">⚕️</span>
            <h3 class="disclaimer-title">Medical Inquiries</h3>
            <p class="disclaimer-text">
              While we provide nutritional guidance, we cannot provide personal medical advice,
              diagnoses, or treatment plans. If you are experiencing a medical emergency, please
              contact your local emergency services or your primary care physician immediately.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .contact-page {
    padding: 3rem 1.5rem 4rem;
  }
  .contact-inner {
    max-width: 64rem;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #1A1A1A;
    margin: 0 0 1rem;
  }
  .page-subtitle {
    font-size: 1.125rem;
    color: #5d5d5d;
    max-width: 32rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .contact-grid { grid-template-columns: 1.3fr 1fr; }
  }

  /* Form Card */
  .form-card {
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem;
    border: 1px solid #e6ede3;
    box-shadow: 0 4px 16px rgba(79, 121, 66, 0.06);
  }

  .card-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 1.5rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    color: #4f4f4f;
    margin-bottom: 0.375rem;
    font-size: 0.875rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid #cddbc7;
    border-radius: 10px;
    font-size: 0.938rem;
    color: #1A1A1A;
    background: #fdfcfb;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    font-family: inherit;
    box-sizing: border-box;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: #4F7942;
    box-shadow: 0 0 0 3px rgba(79, 121, 66, 0.12);
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #b0b0b0;
  }
  .form-group textarea { resize: vertical; }

  .submit-btn {
    width: 100%;
    padding: 0.875rem;
    background: #4F7942;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .submit-btn:hover {
    background: #406338;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(79, 121, 66, 0.25);
  }

  /* Info Cards */
  .info-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-card {
    background: #fff;
    border-radius: 16px;
    padding: 1.75rem;
    border: 1px solid #e6ede3;
  }
  .info-icon {
    display: block;
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }
  .info-title {
    font-size: 1rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.5rem;
  }
  .info-text {
    color: #5d5d5d;
    line-height: 1.6;
    font-size: 0.938rem;
    font-style: normal;
    margin: 0;
  }
  .info-text a {
    color: #4F7942;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }
  .info-text a:hover { color: #344f2e; }

  /* Disclaimer */
  .disclaimer-card {
    background: #fffbf0;
    border-radius: 16px;
    padding: 1.75rem;
    border: 1px solid #ebe5d7;
  }
  .disclaimer-icon {
    display: block;
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .disclaimer-title {
    font-size: 1rem;
    font-weight: 700;
    color: #6e6354;
    margin: 0 0 0.5rem;
  }
  .disclaimer-text {
    font-size: 0.813rem;
    color: #847763;
    line-height: 1.6;
    margin: 0;
  }
</style>
