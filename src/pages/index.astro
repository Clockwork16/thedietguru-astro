---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { fetchGraphQL, GET_POSTS } from '../lib/graphql';

// Fetch latest posts from WordPress
let posts: any[] = [];
let fetchError = false;

try {
  const data = await fetchGraphQL(GET_POSTS, { first: 6 });
  posts = data?.posts?.nodes || [];
} catch (e) {
  fetchError = true;
  console.error('Failed to fetch posts:', e);
}

const pillars = [
  {
    icon: '🧬',
    title: 'Bio-Individual Nutrition',
    desc: 'There is no one-size-fits-all. We tailor protocols to your unique genetic markers and gut microbiome.',
  },
  {
    icon: '🛡️',
    title: 'Anti-Inflammatory Focus',
    desc: 'Rooted in science that targets systemic inflammation—the primary driver of chronic aging.',
  },
  {
    icon: '⚖️',
    title: 'Sustainable Weight Loss',
    desc: 'We prioritize metabolic flexibility over calorie restriction for long-term vitality.',
  },
];
---

<Layout
  title="The Diet Guru — Food is Medicine"
  description="Unlock the science of longevity through personalized, evidence-based nutrition. We bridge the gap between clinical research and your kitchen."
  keywords={['food is medicine', 'diet guru', 'nutrition science', 'longevity', 'healthy eating', 'anti-inflammatory diet']}
>
  <!-- ═══ Hero ═══ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>Medically Reviewed</span>
      </div>
      <h1 class="hero-title">
        <span class="hero-accent">The Diet Guru:</span>
        <br />Food is Medicine
      </h1>
      <p class="hero-subtitle">
        Unlock the science of longevity through personalized, evidence-based nutrition.
        We bridge the gap between clinical research and your kitchen.
      </p>
      <div class="hero-ctas">
        <a href="/recipes" class="btn-primary">Explore Recipes</a>
        <a href="/about" class="btn-secondary">Our Mission →</a>
      </div>
      <p class="hero-credentials">
        Reviewed by <strong>Dr. Sarah Chen, RD</strong> • Certified Health Coach
      </p>
    </div>
  </section>

  <!-- ═══ Featured Article ═══ -->
  <section class="section">
    <div class="section-inner">
      <div class="featured-card">
        <div class="featured-label">
          <span aria-hidden="true">🔬</span>
          Global Health Alert
        </div>
        <h2 class="featured-title">The Pink Pineapple: GMO Luxury or Toxic Trap?</h2>
        <p class="featured-desc">
          We go deep into the genetics of the world's most Instagrammable fruit
          to see if the modifications affect your metabolic health.
        </p>
        <a href="/blog" class="featured-cta">Read the Investigation →</a>
      </div>
    </div>
  </section>

  <!-- ═══ Philosophy Pillars ═══ -->
  <section class="section section-alt">
    <div class="section-inner">
      <h2 class="section-title">Our Philosophy: Food is Medicine</h2>
      <div class="pillars-grid">
        {pillars.map(pillar => (
          <div class="pillar-card">
            <span class="pillar-icon" aria-hidden="true">{pillar.icon}</span>
            <h3 class="pillar-title">{pillar.title}</h3>
            <p class="pillar-desc">{pillar.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ Latest Articles ═══ -->
  <section class="section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Latest Articles</h2>
        <a href="/blog" class="section-link">View All →</a>
      </div>

      {fetchError ? (
        <div class="empty-state">
          <p>Articles are loading... Check back soon!</p>
        </div>
      ) : posts.length > 0 ? (
        <div class="articles-grid">
          {posts.map((post: any) => (
            <PostCard
              slug={post.slug}
              title={post.title}
              excerpt={post.excerpt}
              date={post.date}
              featuredImage={post.featuredImage?.node}
              category={post.categories?.nodes?.[0]?.name}
            />
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>No articles found. New content is coming soon!</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ 21-Day Smoothie CTA ═══ -->
  <section class="cta-banner">
    <div class="section-inner">
      <div class="cta-content">
        <span class="cta-icon" aria-hidden="true">🥤</span>
        <div>
          <h2 class="cta-title">The 21-Day Smoothie Diet</h2>
          <p class="cta-desc">
            Transform your gut health with our curated liquid nutrition protocol.
            Scientifically balanced macros in every sip.
          </p>
        </div>
        <a href="/recipes" class="btn-cta">Start Your Journey</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ─── Hero ─── */
  .hero {
    background: linear-gradient(160deg, #f4f7f3 0%, #e6ede3 40%, #cddbc7 100%);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
  }
  .hero-inner {
    max-width: 48rem;
    margin: 0 auto;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    background: rgba(79, 121, 66, 0.12);
    border: 1px solid #abc09f;
    border-radius: 24px;
    font-size: 0.813rem;
    font-weight: 600;
    color: #344f2e;
    margin-bottom: 2rem;
  }
  .badge-dot {
    width: 8px;
    height: 8px;
    background: #4F7942;
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #1A1A1A;
    line-height: 1.15;
    margin: 0 0 1.5rem;
    letter-spacing: -0.03em;
  }
  .hero-accent { color: #4F7942; }

  .hero-subtitle {
    font-size: 1.125rem;
    color: #4f4f4f;
    line-height: 1.7;
    margin: 0 0 2rem;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .btn-primary {
    padding: 0.875rem 2rem;
    background: #4F7942;
    color: #fff;
    font-weight: 700;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 4px 12px rgba(79, 121, 66, 0.25);
  }
  .btn-primary:hover {
    background: #406338;
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(79, 121, 66, 0.3);
  }

  .btn-secondary {
    padding: 0.875rem 2rem;
    background: transparent;
    color: #4F7942;
    font-weight: 600;
    border: 2px solid #4F7942;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover {
    background: #4F7942;
    color: #fff;
  }

  .hero-credentials {
    font-size: 0.813rem;
    color: #6d6d6d;
    margin: 0;
  }

  /* ─── Sections ─── */
  .section {
    padding: 4rem 1.5rem;
  }
  .section-alt {
    background: #fff;
  }
  .section-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: #1A1A1A;
    margin: 0 0 2rem;
    text-align: center;
  }
  .section-header .section-title {
    text-align: left;
    margin-bottom: 0;
  }

  .section-link {
    font-weight: 600;
    color: #4F7942;
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .section-link:hover { color: #344f2e; }

  /* ─── Featured Card ─── */
  .featured-card {
    background: linear-gradient(135deg, #fff 0%, #f4f7f3 100%);
    border: 2px solid #cddbc7;
    border-radius: 20px;
    padding: 2.5rem;
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
    transition: border-color 0.3s;
  }
  .featured-card:hover { border-color: #4F7942; }

  .featured-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.813rem;
    font-weight: 700;
    color: #d9534f;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }

  .featured-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: #1A1A1A;
    margin: 0 0 1rem;
  }

  .featured-desc {
    color: #5d5d5d;
    line-height: 1.7;
    margin: 0 0 1.5rem;
  }

  .featured-cta {
    font-weight: 700;
    color: #4F7942;
    text-decoration: none;
    transition: color 0.2s;
  }
  .featured-cta:hover { color: #344f2e; }

  /* ─── Pillars ─── */
  .pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .pillars-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .pillar-card {
    padding: 2rem;
    background: #f9f7f2;
    border-radius: 16px;
    border: 1px solid #e6ede3;
    text-align: center;
    transition: all 0.3s;
  }
  .pillar-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(79, 121, 66, 0.1);
    border-color: #abc09f;
  }

  .pillar-icon {
    display: block;
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .pillar-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.75rem;
  }

  .pillar-desc {
    font-size: 0.875rem;
    color: #5d5d5d;
    line-height: 1.6;
    margin: 0;
  }

  /* ─── Articles Grid ─── */
  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .articles-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: #888;
    background: #fff;
    border-radius: 16px;
    border: 2px dashed #cddbc7;
  }

  /* ─── CTA Banner ─── */
  .cta-banner {
    padding: 0 1.5rem;
    margin-bottom: -2rem;
  }
  .cta-content {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
    background: linear-gradient(135deg, #4F7942, #2b4026);
    border-radius: 20px;
    padding: 2.5rem;
    color: #fff;
    flex-wrap: wrap;
  }

  .cta-icon {
    font-size: 3rem;
    flex-shrink: 0;
  }

  .cta-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
  }

  .cta-desc {
    margin: 0;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
  }

  .btn-cta {
    margin-left: auto;
    padding: 0.875rem 2rem;
    background: #fff;
    color: #4F7942;
    font-weight: 700;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .btn-cta:hover {
    background: #f4f7f3;
    transform: translateY(-1px);
  }
</style>