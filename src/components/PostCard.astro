---
interface Props {
  slug: string;
  title: string;
  excerpt?: string;
  date?: string;
  featuredImage?: { sourceUrl: string; altText?: string } | null;
  category?: string;
}

const { slug, title, excerpt, date, featuredImage, category } = Astro.props;

const formattedDate = date ? new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}) : null;

// Strip HTML tags from excerpt
const cleanExcerpt = excerpt?.replace(/<[^>]*>/g, '').trim();
---

<a href={`/blog/${slug}`} class="post-card" id={`post-${slug}`}>
  <div class="card-image">
    {featuredImage ? (
      <img
        src={featuredImage.sourceUrl}
        alt={featuredImage.altText || title}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="card-image-placeholder">
        <span aria-hidden="true">📝</span>
      </div>
    )}
    {category && <span class="card-badge">{category}</span>}
  </div>
  <div class="card-body">
    {formattedDate && <time class="card-date" datetime={date}>{formattedDate}</time>}
    <h3 class="card-title">{title}</h3>
    {cleanExcerpt && <p class="card-excerpt">{cleanExcerpt.slice(0, 150)}{cleanExcerpt.length > 150 ? '…' : ''}</p>}
    <span class="card-cta">Read Article →</span>
  </div>
</a>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 8px rgba(79, 121, 66, 0.06);
    border: 1px solid #e6ede3;
    transition: all 0.3s ease;
  }
  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(79, 121, 66, 0.12);
    border-color: #abc09f;
  }

  .card-image {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #e6ede3;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .post-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background: linear-gradient(135deg, #e6ede3, #f4f7f3);
  }

  .card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: rgba(79, 121, 66, 0.9);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-date {
    font-size: 0.813rem;
    color: #888;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.5rem;
    line-height: 1.4;
    transition: color 0.2s;
  }
  .post-card:hover .card-title {
    color: #4F7942;
  }

  .card-excerpt {
    font-size: 0.875rem;
    color: #5d5d5d;
    line-height: 1.6;
    margin: 0 0 1rem;
    flex: 1;
  }

  .card-cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: #4F7942;
    transition: color 0.2s;
  }
  .post-card:hover .card-cta { color: #344f2e; }
</style>
