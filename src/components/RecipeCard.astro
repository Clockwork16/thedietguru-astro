---
interface Props {
  slug: string;
  title: string;
  excerpt?: string;
  featuredImage?: { sourceUrl: string; altText?: string } | null;
  calories?: string;
  protein?: string;
  prepTime?: string;
  hoverLabel?: string;
  linkBase?: string;
}

const { slug, title, excerpt, featuredImage, calories, protein, prepTime, hoverLabel = 'View Details', linkBase = '/recipes' } = Astro.props;

const cleanExcerpt = excerpt?.replace(/<[^>]*>/g, '').trim();
---

<a href={`${linkBase}/${slug}`} class="recipe-card" id={`recipe-${slug}`}>
  <div class="recipe-image">
    {featuredImage ? (
      <img
        src={featuredImage.sourceUrl}
        alt={featuredImage.altText || title}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="recipe-image-placeholder">
        <span aria-hidden="true">🥗</span>
      </div>
    )}
    <div class="recipe-overlay">
      <span>{hoverLabel}</span>
    </div>
  </div>

  <div class="recipe-body">
    <h3 class="recipe-title">{title}</h3>
    {cleanExcerpt && (
      <p class="recipe-excerpt">{cleanExcerpt.slice(0, 100)}{cleanExcerpt.length > 100 ? '…' : ''}</p>
    )}

    <div class="recipe-meta">
      {calories && (
        <span class="meta-pill">
          <span aria-hidden="true">🔥</span> {calories} cal
        </span>
      )}
      {protein && (
        <span class="meta-pill">
          <span aria-hidden="true">💪</span> {protein} protein
        </span>
      )}
      {prepTime && (
        <span class="meta-pill">
          <span aria-hidden="true">⏱️</span> {prepTime}
        </span>
      )}
    </div>
  </div>
</a>

<style>
  .recipe-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 2px solid #cddbc7;
    box-shadow: 0 2px 8px rgba(79, 121, 66, 0.06);
    transition: all 0.3s ease;
    position: relative;
  }
  .recipe-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(79, 121, 66, 0.15);
    border-color: #4F7942;
  }

  .recipe-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e6ede3;
  }
  .recipe-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .recipe-card:hover .recipe-image img {
    transform: scale(1.08);
  }

  .recipe-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    background: linear-gradient(135deg, #e6ede3 0%, #cddbc7 100%);
  }

  .recipe-overlay {
    position: absolute;
    inset: 0;
    background: rgba(45, 89, 39, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .recipe-card:hover .recipe-overlay { opacity: 1; }
  .recipe-overlay span {
    color: #fff;
    font-weight: 700;
    font-size: 1.125rem;
    padding: 0.75rem 1.5rem;
    border: 2px solid #fff;
    border-radius: 8px;
  }

  .recipe-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .recipe-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.5rem;
    line-height: 1.3;
    transition: color 0.2s;
  }
  .recipe-card:hover .recipe-title { color: #4F7942; }

  .recipe-excerpt {
    font-size: 0.875rem;
    color: #5d5d5d;
    line-height: 1.5;
    margin: 0 0 1rem;
    flex: 1;
  }

  .recipe-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.625rem;
    background: #f4f7f3;
    border: 1px solid #cddbc7;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    color: #406338;
  }
</style>
